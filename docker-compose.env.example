# Copy this file to .env before running Docker Compose. Generate long, unique
# values for every password and URI-encode credentials embedded in MONGO_URI.
MONGO_ROOT_USERNAME=otaku_root
MONGO_ROOT_PASSWORD=replace-with-a-long-random-root-password
MONGO_APP_USERNAME=otaku_app
MONGO_APP_PASSWORD=replace-with-a-long-random-app-password
MONGO_URI=mongodb://otaku_app:replace-with-a-uri-encoded-app-password@mongodb:27017/otaku_world?authSource=otaku_world

JWT_SECRET=replace-with-at-least-32-random-characters
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FRONTEND_URL=https://your-frontend-domain.example
# Comma-separated HTTPS origins for intentional preview or alternate frontends.
ADDITIONAL_ALLOWED_ORIGINS=
